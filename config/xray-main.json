{
  "log": {
    "access": "/var/log/xray-main-access.log",
    "error": "/var/log/xray-main-error.log",
    "loglevel": "warning"
  },
  "inbounds": [
    {
      "tag": "vless-reality",
      "port": 443,
      "protocol": "vless",
      "settings": {
        "clients": [
          {
            "id": "$USER_UUID",
            "flow": "xtls-rprx-vision",
            "email": "vless-reality@zephyrox"
          }
        ],
        "decryption": "none"
      },
      "streamSettings": {
        "network": "tcp",
        "security": "reality",
        "realitySettings": {
          "show": false,
          "dest": "www.cloudflare.com:443",
          "serverNames": [
            "www.cloudflare.com",
            "www.microsoft.com",
            "www.apple.com"
          ],
          "privateKey": "$XRAY_PRIVATE_KEY",
          "shortIds": ["$SHORT_ID"]
        }
      }
    },
    {
      "tag": "vmess-ws",
      "port": 8080,
      "protocol": "vmess",
      "settings": {
        "clients": [
          {
            "id": "$USER_UUID",
            "alterId": 0,
            "email": "vmess-ws@zephyrox"
          }
        ]
      },
      "streamSettings": {
        "network": "ws",
        "security": "none",
        "wsSettings": {
          "path": "/vmess-ws"
        }
      }
    },
    {
      "tag": "trojan-tls",
      "port": 2083,
      "protocol": "trojan",
      "settings": {
        "clients": [
          {
            "password": "$USER_UUID",
            "email": "trojan-tls@zephyrox"
          }
        ]
      },
      "streamSettings": {
        "network": "tcp",
        "security": "tls",
        "tlsSettings": {
          "certificates": [
            {
              "certificateFile": "/etc/ssl/private/cert.pem",
              "keyFile": "/etc/ssl/private/privkey.pem"
            }
          ]
        }
      }
    }
  ],
  "outbounds": [
    {
      "tag": "direct",
      "protocol": "freedom",
      "settings": {
        "domainStrategy": "UseIP"
      }
    },
    {
      "tag": "blocked",
      "protocol": "blackhole",
      "settings": {}
    },
    {
      "tag": "local-direct",
      "protocol": "freedom",
      "settings": {
        "redirect": "",
        "domainStrategy": "UseIP"
      }
    }
  ],
  "routing": {
    "domainStrategy": "AsIs",
    "rules": [
      {
        "type": "field",
        "outboundTag": "blocked",
        "domain": ["geosite:category-ads-all"]
      },
      {
        "type": "field",
        "outboundTag": "local-direct",
        "domain": [
          "domain:vk.com",
          "domain:ok.ru",
          "domain:mail.ru",
          "domain:yandex.ru",
          "domain:avito.ru",
          "domain:ozon.ru",
          "domain:wildberries.ru",
          "domain:sberbank.ru"
        ]
      }
    ]
  }
}
